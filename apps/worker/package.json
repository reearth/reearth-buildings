{
  "name": "@reearth-buildings/worker",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker for buildings.reearth.land (TS host + Rust→WASM hot path)",
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/buildings-wasm --target bundler --out-dir ../../apps/worker/wasm --release",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "dev": "pnpm run build:wasm && wrangler dev",
    "deploy": "pnpm run build:wasm && wrangler deploy",
    "deploy:staging": "pnpm run build:wasm && wrangler deploy --env staging",
    "deploy:prod": "pnpm run build:wasm && wrangler deploy --env prod"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "pmtiles": "^4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@cloudflare/workers-types": "^4.20251001.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
